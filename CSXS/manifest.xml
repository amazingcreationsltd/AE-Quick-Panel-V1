        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AE-Quick Panel</Menu>
          <Geometry>
            <PreferredSize>
              <Width>310</Width>
              <Height>720</Height>
            </PreferredSize>
            <MinSize>
              <Width>260</Width>
              <Height>600</Height>
            </MinSize>
          </Geometry>
          <Icons/>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
