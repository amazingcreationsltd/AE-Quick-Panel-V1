<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest Version="7.0"
  ExtensionBundleId="com.debu.aequickpanel"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="AE-Quick Panel V1">
